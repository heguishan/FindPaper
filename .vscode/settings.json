{
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "tests"
  ],
  "files.encoding": "utf8",
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    ".pytest_cache": true,
    ".ruff_cache": true,
    ".venv": true,
    "downloads": true,
    "findpaper.egg-info": true
  },
  "search.exclude": {
    ".venv": true,
    "downloads": true,
    "findpaper.egg-info": true
  }
}

